10000 '  DUMPING VARIABLE TABLE
10010 '  ****** IN BASIC ******
10020 '
10030 ' TEST DATA FOLLOWS
10040 ' DIM A,AA,BB,CC$,C$,DD
10050 ' DIM E,EE,E$,EE$,F,FF$
10060 ' DIM G,GG$,HH,H,H$,HH$
10070 ' TEST DATA END
10080 '
10090 SV=PEEK(27)*256+PEEK(28)
10100 EV=PEEK(29)*256+PEEK(30)
10110 FOR I=SV TO EV STEP 7
10120 P1=PEEK(I):P2=PEEK(I+1)
10130 PRINT CHR$(P1);
10140 PRINT CHR$(P2 AND &H7F);
10150 IF P2 AND &H80 THEN PRINT "$ "; ELSE PRINT "  ";
10160 IF (P2 AND &H7F) = 0 THEN PRINT " ";
10170 NEXT
